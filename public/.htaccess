<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# === ANTI-CLONAGEM / SEGURANCA ===

# Bloqueia iframe (anti-phishing/clonagem)
<IfModule mod_headers.c>
  Header always set X-Frame-Options "DENY"
  Header always set Content-Security-Policy "frame-ancestors 'none'"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "no-referrer"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Bloqueia acesso direto ao código fonte
<FilesMatch "\.(js|map|ts|tsx|jsx)$">
  <IfModule mod_headers.c>
    Header set X-Robots-Tag "noindex, nofollow, nosnippet, noarchive"
  </IfModule>
</FilesMatch>

# Bloqueia source maps em produção
<FilesMatch "\.map$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Bloqueia bots de scraping conhecidos
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_USER_AGENT} (HTTrack|WebCopier|WebZIP|Teleport|wget|curl|Scrapy|SiteSucker|pavuk) [NC]
  RewriteRule .* - [F,L]
</IfModule>

# Bloqueia hotlinking de assets
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_REFERER} !^$ [NC]
  RewriteCond %{HTTP_REFERER} !^https?://(www\.)?extratoslive\.shop [NC]
  RewriteCond %{HTTP_REFERER} !^https?://(www\.)?extratolive\.shop [NC]
  RewriteCond %{HTTP_REFERER} !^https?://localhost [NC]
  RewriteRule \.(js|css|png|jpg|svg|ico|woff2?)$ - [F,L]
</IfModule>
